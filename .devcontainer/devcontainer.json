{
  "name": "Transport Deluxe DevPod",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "overrideCommand": true,
  "remoteUser": "root",
  "remoteEnv": {
    "COMPOSE_PROJECT_NAME": "transport-deluxe"
  },
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "postCreateCommand": "apt-get update && apt-get install -y docker.io docker-compose && cp ~/.env /workspace/.env 2>/dev/null || true && pip install uv && uv sync --all-packages",
  "postStartCommand": "bash /workspace/.devcontainer/setup-ports.sh",
  "forwardPorts": [
    5050,
    8000,
    8001,
    8002,
    8003,
    8004,
    8005,
    8006,
    8007,
    8008
  ]
}
